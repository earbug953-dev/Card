APP_NAME="Membership Card"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ───────────────────────────────────────────────
# Option A: SQLite (easiest for local setup – no server needed)
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite
# Leave DB_DATABASE blank to auto-use database/database.sqlite

# Option B: MySQL
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=membership_card
# DB_USERNAME=root
# DB_PASSWORD=

# Option C: PostgreSQL
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=membership_card
# DB_USERNAME=postgres
# DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@membershipcard.com"
MAIL_FROM_NAME="${APP_NAME}"
